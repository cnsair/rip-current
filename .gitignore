# Ignore compiled Python files
*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class

# Ignore Python bytecode cache
__pycache__/
**/__pycache__/

# Ignore project-specific folders, file types, and compressed files
# Ignore everything inside these folders
data/*
datasets/*
data_two/
data_three/

# But do not ignore the .gitkeep files inside them
!data/.gitkeep
!datasets/.gitkeep
*.zip
*.tar.gz
*.jpg
*.jpeg
*.png
*.mp4
*.avi

# Ignore VSCode IDE settings
.vscode/

# Environments
venv/
env/
.env

# OS generated files
.DS_Store
Thumbs.db