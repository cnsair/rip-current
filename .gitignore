# Ignore compiled Python files
*.pyc
*.pyo
*.pyd
*.py[cod]
*$py.class

# Ignore Python bytecode cache
__pycache__/
**/__pycache__/

# Ignore project-specific folders, file types, and compressed files
# Ignore everything inside these folders
data/*
datasets/*
data_two/
data_three/
kaggle_upload/
mit-b2-local/*
segformer-b2-local/*

# But do not ignore the .gitkeep files inside them
!data/.gitkeep
!datasets/.gitkeep
!mit-b2-local/.gitkeep
!segformer-b2-local/.gitkeep
*.zip
*.tar.gz
*.jpg
*.jpeg
*.png
*.mp4
*.avi
*.pth
*.h5
*.weights
*.log

# Ignore VSCode IDE settings
.vscode/

# Environments
venv/
env/
.env
.code-profile

# OS generated files
.DS_Store
Thumbs.db